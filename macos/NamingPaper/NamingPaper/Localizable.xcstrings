    "Could not connect to the AI provider. Make sure Ollama or your configured provider is running." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo conectar al proveedor de IA. Asegúrate de que Ollama o tu proveedor configurado esté en ejecución."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI プロバイダに接続できませんでした。Ollama または設定済みのプロバイダが実行中であることを確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "AI 공급자에 연결할 수 없습니다. Ollama 또는 설정한 공급자가 실행 중인지 확인하세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "无法连接到 AI 供应商。请确保 Ollama 或您配置的供应商正在运行。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "無法連接到 AI 供應商。請確保 Ollama 或您設定的供應商正在執行。"
          }
        }
      }
    },
    "Could not recognize this PDF as an academic paper. It may not contain extractable metadata." : {
      "localizations" : {
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo reconocer este PDF como un artículo académico. Es posible que no contenga metadatos extraíbles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この PDF を学術論文として認識できませんでした。抽出可能なメタデータが含まれていない可能性があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 PDF를 학술 논문으로 인식할 수 없습니다. 추출 가능한 메타데이터가 없을 수 있습니다."
          }
        },
        "zh-Hans" : {
